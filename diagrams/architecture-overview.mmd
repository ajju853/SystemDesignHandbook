%% High-level System Architecture Overview

graph TD
    subgraph "Clients"
        WEB[Web Browser]
        MOBILE[Mobile App]
        API_CLI[External API Client]
    end

    subgraph "Edge Layer"
        CDN[CDN / CloudFront]
        DNS[DNS / Route53]
        WAF[WAF / DDoS Protection]
    end

    subgraph "Gateway Layer"
        LB[Load Balancer<br/>ALB/NLB]
        GW[API Gateway]
    end

    subgraph "Application Layer"
        S1[Service 1<br/>User Service]
        S2[Service 2<br/>Order Service]
        S3[Service 3<br/>Payment Service]
        S4[Service 4<br/>Notification Service]
        S5[Service 5<br/>Search Service]
    end

    subgraph "Data Layer"
        RDS[(RDS / PostgreSQL)]
        NOSQL[(DynamoDB / Cassandra)]
        CACHE[(Redis / Memcached)]
        S3[(S3 / Object Storage)]
    end

    subgraph "Message Layer"
        K[Kafka / Event Bus]
        Q[SQS / RabbitMQ]
    end

    subgraph "Observability"
        PROM[Prometheus]
        GRAF[Grafana]
        ELK[ELK Stack]
        TRACE[Jaeger / X-Ray]
    end

    WEB --> CDN
    MOBILE --> CDN
    CDN --> LB
    LB --> GW
    GW --> S1
    GW --> S2
    GW --> S3
    GW --> S4
    GW --> S5

    S1 --> RDS
    S2 --> NOSQL
    S3 --> RDS
    S4 --> K
    S5 --> NOSQL

    S1 --> CACHE
    S2 --> CACHE
    S3 --> K
    S4 --> Q
    S4 --> S3

    S1 -.-> PROM
    S2 -.-> PROM
    S1 -.-> ELK
    S2 -.-> TRACE

    style WEB fill:#4CAF50,color:#fff
    style MOBILE fill:#4CAF50,color:#fff
    style RDS fill:#FF9800,color:#fff
    style NOSQL fill:#FF9800,color:#fff
    style CACHE fill:#E91E63,color:#fff
    style K fill:#9C27B0,color:#fff
